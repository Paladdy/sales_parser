# Host ports (change if busy — run `make ports` to check)
POSTGRES_HOST_PORT=55433
ENRICHER_HOST_PORT=18080
N8N_HOST_PORT=15678

# Service config
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
DATABASE_URL=postgresql://lead:lead@postgres:5432/lead_enricher
DATABASE_URL_HOST=postgresql://lead:lead@localhost:55433/lead_enricher
FETCH_TIMEOUT_SEC=15
USE_PLAYWRIGHT=false
HOT_SCORE_THRESHOLD=80
WARM_SCORE_THRESHOLD=50
N8N_WEBHOOK_URL=http://localhost:15678/webhook/new-lead
ENRICH_URL=http://localhost:18080/enrich-lead
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
CACHE_TTL_HOURS=24
USE_FIXTURE_FETCHER=true
